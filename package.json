{
	"name": "rp-theme",
	"version": "1.0.0",
	"description": "running website theme",
	"author": "",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"WordPress",
		"Theme"
	],
	"engines": {
		"node": ">=20.10.0",
		"npm": ">=10.2.3"
	},
	"devDependencies": {
		"@wordpress/scripts": "^32.1.0",
		"cssnano": "^7.1.2",
		"postcss": "^8.5.6",
		"postcss-cli": "^11.0.1",
		"postcss-import": "^16.1.0",
		"postcss-preset-env": "^10.1.6"
	},
	"scripts": {
		"start": "wp-scripts start & postcss resources/styles/style.css -o public/style.css --watch",
		"build": "npm run build:styles && npm run build:js",
		"build:js": "wp-scripts build",
		"build:styles": "NODE_ENV=production postcss resources/styles/style.css -o public/style.css",
		"watch:styles": "postcss resources/styles/style.css -o public/style.css --watch"
	}
}
